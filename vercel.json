{
  "version": 2,
  "functions": {
    "api/earnings.ts": { "maxDuration": 60 },
    "api/stock/[symbol].ts": { "maxDuration": 30 },
    "api/quote/[symbol].ts": { "maxDuration": 15 },
    "api/earnings/[symbol].ts": { "maxDuration": 30 },
    "api/sentiment.ts": { "maxDuration": 30 },
    "api/macro.ts": { "maxDuration": 30 },
    "api/yields.ts": { "maxDuration": 25 },
    "api/breadth.ts": { "maxDuration": 45 },
    "api/cot.ts": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Credentials", "value": "true" },
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT" },
        { "key": "Access-Control-Allow-Headers", "value": "X-CSRF-Token, X-Requested-With, Accept, Accept-Version, Content-Length, Content-MD5, Content-Type, Date, X-Api-Version" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/earnings/:symbol", "destination": "/api/earnings/[symbol]" },
    { "source": "/api/stock/:symbol",    "destination": "/api/stock/[symbol]" },
    { "source": "/api/quote/:symbol",    "destination": "/api/quote/[symbol]" },
    { "source": "/(.*)",                 "destination": "/index.html" }
  ]
}
